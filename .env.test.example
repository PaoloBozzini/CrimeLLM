# CrimeLLM — test-only Neo4j env. Copy to .env.test (gitignored) or `source`
# before running pytest. The test fixture in tests/conftest.py REFUSES to
# touch Neo4j unless CRIMELLM_TEST_NEO4J_URI is set explicitly, so tests
# cannot accidentally wipe the dev/prod DB.
#
# Spin up the isolated container:
#   docker compose -f docker-compose.test.yml up -d
#
# Then either `source .env.test` or pass these inline to pytest.

CRIMELLM_TEST_NEO4J_URI=bolt://localhost:7688
CRIMELLM_TEST_NEO4J_USER=neo4j
CRIMELLM_TEST_NEO4J_PASSWORD=crimellm-test
CRIMELLM_TEST_NEO4J_DATABASE=neo4j
