# CrimeLLM — secrets template. Copy this to `.env` and fill in your tokens.
# `.env` is gitignored. Loaded automatically by crimellm.env.load_env() and
# by downloaders (download_courtlistener, download_us_code) when no
# explicit token is passed.

# CourtListener — free signup at https://www.courtlistener.com/sign-up/
# then create a token at https://www.courtlistener.com/help/api/
COURTLISTENER_API_TOKEN=


# api.data.gov — free signup at https://api.data.gov/signup/
# Used by download_us_code for govinfo.gov access. DEMO_KEY = 30 req/hour.
# A real key raises the limit to 1000 req/hour.
GOVINFO_API_KEY=

# Anthropic API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- clg (Common Legal Graph) pipeline -------------------------------------

# Neo4j (run via `docker compose up -d neo4j`). Defaults match docker-compose.yml.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=crimellm-dev
NEO4J_DATABASE=neo4j

# Voyage AI — legal-domain embeddings (voyage-law-2). https://www.voyageai.com/
VOYAGE_API_KEY=

# Find Case Law (TNA) — programmatic bulk extraction requires applying for the
# free computational-analysis licence. Set to 1 to acknowledge before enabling
# the bulk downloader. See https://caselaw.nationalarchives.gov.uk/
TNA_COMPUTATIONAL_LICENCE_ACCEPTED=0
