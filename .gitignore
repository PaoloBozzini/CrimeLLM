.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
artifacts/
crime_classifier/
runs/
wandb/
*.egg-info/
dist/
build/
.uv-cache/
.env
.env.local
.env.test
*.local.*

# `data/` payloads are gitignored, but the scaffolding (sample CSV + .gitkeep
# markers under raw/interim/processed/cache) stays in git so a fresh checkout
# has the expected layout.
data/*
!data/sample.csv
!data/raw/
!data/interim/
!data/processed/
!data/cache/
data/raw/*
data/interim/*
data/processed/*
data/cache/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/cache/.gitkeep

!data/eval/
!data/eval/**

# Proprietary gold sets / firm-specific eval data — kept out of the public
# repo by convention. Public `data/eval/seed.yaml` stays in.
data/eval/private/
data/eval/firm_*
data/eval/*.private.*
