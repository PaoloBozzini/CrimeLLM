    <Kapitel id="k1" localId="1">
      <Explicatus>Kapitel 1</Explicatus>
      <Rubrica>Lovens anvendelsesområde</Rubrica>
      <Paragraf id="p1" localId="1">
        <Explicatus>§ 1.</Explicatus>
        <Stk id="p1s1">
          <Explicatus>Stk. 1.</Explicatus>
          <Exitus><Linea><Char>Loven supplerer reglerne i databeskyttelsesforordningen.</Char></Linea></Exitus>
        </Stk>
        <Stk id="p1s2">
          <Explicatus>Stk. 2.</Explicatus>
          <Exitus><Linea><Char>Loven gælder for behandling af personoplysninger som nævnt i databeskyttelsesforordningens artikel 2.</Char></Linea></Exitus>
        </Stk>
      </Paragraf>
      <Paragraf id="p6" localId="6">
        <Explicatus>§ 6.</Explicatus>
        <Stk id="p6s1">
          <Explicatus>Stk. 1.</Explicatus>
          <Exitus id="p6s1e1">
            <Index>
              <Indentatio id="p6s1n1" formaInd="Nummer">
                <Explicatus>1)</Explicatus>
                <Exitus><Linea><Char>Behandling må kun finde sted, hvis mindst en af betingelserne i databeskyttelsesforordningens artikel 6, stk. 1, er opfyldt.</Char></Linea></Exitus>
              </Indentatio>
              <Indentatio id="p6s1n2" formaInd="Nummer">
                <Explicatus>2)</Explicatus>
                <Exitus><Linea><Char>Behandling kan ske, hvis den registrerede har givet samtykke.</Char></Linea></Exitus>
              </Indentatio>
            </Index>
          </Exitus>
        </Stk>
      </Paragraf>
    </Kapitel>
    <Paragraf id="p36" localId="36">
